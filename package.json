{
  "name": "siptracker",
  "displayName": "Sip Tracker",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "siptracker.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "siptracker.stop",
        "title": "Stop Timer"
      },
      {
        "command": "siptracker.reset",
        "title": "Reset Timer"
      },
      {
        "command": "siptracker.start",
        "title": "Start Timer"
      },
      {
        "command": "siptracker.showStats",
        "title": "Show Stats"
      }
    ],
    "configuration": {
      "title": "siptracker",
      "properties": {
        "siptracker.sipInterval": {
          "type": "number",
          "default": 0.25,
          "min": 0,
          "description": "How often to remind you to drink water (in minutes)"
        },
        "siptracker.sipMsg" :{
          "type" : "string",
          "default" : "Time For a Sip!!",
          "description": "Set your own reminder message"
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}